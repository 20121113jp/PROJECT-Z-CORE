{
  "name": "claw-fusion",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Clean-room integration kit for Claude Code, Cowork-adjacent workflows, OpenClaw, and MCP ecosystems",
  "bin": {
    "claw-fusion": "./claw-fusion.mjs"
  },
  "scripts": {
    "test": "node --test",
    "fusion:status": "node ./claw-fusion.mjs status",
    "fusion:doctor": "node ./claw-fusion.mjs doctor",
    "fusion:sources": "node ./claw-fusion.mjs sources",
    "fusion:matrix": "node ./scripts/render-vendor-matrix.mjs",
    "fusion:bootstrap:print": "node ./scripts/bootstrap-official-sources.mjs --print"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "claude-code",
    "cowork",
    "openclaw",
    "mcp",
    "integration"
  ],
  "license": "MIT"
}
